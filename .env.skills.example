# Copy this file to ~/.claude/.env.skills and fill in your values
# Then add this line to ~/.zshrc:
#   [ -f ~/.claude/.env.skills ] && source ~/.claude/.env.skills
# Finally: chmod 600 ~/.claude/.env.skills

# =============================================================================
# Buffer API — Primary account (Instagram + TikTok)
# =============================================================================
export BUFFER_API_KEY_PRIMARY="your-buffer-api-key-here"
export BUFFER_CHANNEL_IG="your-instagram-channel-id-here"
export BUFFER_CHANNEL_TIKTOK="your-tiktok-channel-id-here"

# =============================================================================
# Buffer API — Secondary account (LinkedIn, optional)
# =============================================================================
export BUFFER_API_KEY_SECONDARY="your-linkedin-api-key-here"
export BUFFER_CHANNEL_LINKEDIN="your-linkedin-channel-id-here"

# =============================================================================
# How to get these values:
# 1. Go to https://publish.buffer.com and log in
# 2. Settings → Developer → Generate API key
# 3. Run the GraphQL query inside SKILL.md to find your channel IDs
# =============================================================================
